	$(MAKE) $(MAKESILENT) -f CMakeFiles\TheRealCampusBallot.dir\build.make CMakeFiles/TheRealCampusBallot.dir/src/ui/views/VotingKiosk.cpp.obj
.PHONY : src/ui/views/VotingKiosk.cpp.obj

src/ui/views/VotingKiosk.i: src/ui/views/VotingKiosk.cpp.i
.PHONY : src/ui/views/VotingKiosk.i

